#.rst
# FinduFilterPickerPickBroker
# ---------------------------
#
# Finds the UUSS filter picker pick broker library.
#
# Imported Targets
# ^^^^^^^^^^^^^^^^
#
# ``uFilterPickerPickBroker_FOUND``
#   True indicates uFilterPickerPickBroker was found.
# ``uFilterPickerPickBroker::uFilterPickerPickBroker``
#   The filter picker pick broker library, if found.
include(CMakeFindDependencyMacro)

find_dependency(TBB)

@PACKAGE_INIT@

include("${CMAKE_CURRENT_LIST_DIR}/@PROJECT_NAME@Targets.cmake")
